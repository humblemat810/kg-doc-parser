# Copy this file to `.env` and fill in real values locally.
# Do not commit real API keys or machine-specific paths.

GOOGLE_API_KEY="your-google-api-key"
FREE_KEY="your-google-api-key"
LANGSMITH_TRACING=false

# Optional file list inputs used by some test and batch flows.
# These can be relative or absolute paths to allow-list files.
ocr_file_list="allow_split_pages.txt"
split_raw_file_list="allow_split_pages.txt"
answer_export_list="unique_new_file_by_index.txt"
